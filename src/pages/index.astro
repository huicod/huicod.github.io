---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { projects } from "../data/projects";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug"

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const last_posts = posts.slice(0, 3);
const featuredProjects = projects.filter((project) => project.featured);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hey there 👋</div>
    <div class="text-5xl font-bold">I'm huicod</div>
    <div class="text-3xl py-3 font-bold">Systems, AI & 3D Interaction</div>
    <div class="py-2">
      <p class="text-lg leading-8">
        I'm currently studying at Sun Yat-sen University. This site collects my projects, paper notes, and
        engineering experiments around distributed systems, AI engineering, and 3D interaction. Long term, I hope
        to build interactive agents that can perceive, reason, and act inside shared 3D spaces.
      </p>
    </div>
    <div class="mt-8">
      <a class="btn" href="mailto:hui10w01@163.com">Let's connect!</a>
      <a href="https://github.com/huicod" target="_blank" class="btn btn-outline ml-5">
        Visit my GitHub
      </a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">Featured projects {"</>"}</div>
  </div>

  {
    featuredProjects.map((project, index) => (
      <>
        <HorizontalCard
          title={project.title}
          desc={project.desc}
          url={project.url}
          badge={project.badge}
          tags={project.tags}
          tagLinks={false}
        />
        {index < featuredProjects.length - 1 && <div class="divider my-0" />}
      </>
    ))
  }

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Latest from blog</div>
  </div>

  {
    last_posts.map((post) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.thumbnailImage ?? post.data.heroImage}
          imgClass={post.data.thumbnailImage ? "w-20 h-20 md:w-24 md:h-24 rounded-xl object-contain shrink-0" : undefined}
          imgWidth={post.data.thumbnailImage ? 96 : 750}
          imgHeight={post.data.thumbnailImage ? 96 : 422}
          desc={post.data.description}
          url={"/blog/" + createSlug(post.data.title, post.slug)}
          target="_self"
          badge={post.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>